generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Config {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([key])
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String
  description String?
  projectId   String
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
}

model AuditLog {
  id            String         @id @default(cuid())
  action        String
  targetType    String
  targetId      String
  scopeType     AuditScopeType @default(GLOBAL)
  projectId     String?
  actorType     AuditActorType @default(SYSTEM)
  actorId       String?
  userId        String?
  correlationId String?
  version       Int            @default(1)
  payload       Json?
  createdAt     DateTime       @default(now()) @db.Timestamptz
  User          User?          @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([userId, createdAt])
}

model Enterprise {
  id               String             @id @default(cuid())
  name             String
  domain           String?            @unique
  externalId       String?            @unique
  platform         String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  EnterpriseMember EnterpriseMember[]
}

model EnterpriseMember {
  id           String     @id @default(cuid())
  enterpriseId String
  userId       String
  role         String     @default("member")
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz
  Enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, userId])
}

model Key {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        KeyType       @default(TEXT)
  namespaceId String
  createdAt   DateTime      @default(now()) @db.Timestamptz
  updatedAt   DateTime      @updatedAt @db.Timestamptz
  Namespace   Namespace     @relation(fields: [namespaceId], references: [id])
  Translation Translation[]

  @@unique([namespaceId, name])
}

model Locale {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ProjectLocale ProjectLocale[]
  Translation   Translation[]
}

model Namespace {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Key         Key[]
  Project     Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, name])
}

model Project {
  id                                        String           @id @default(cuid())
  name                                      String
  description                               String?
  baseLocale                                String           @default("zh-CN")
  createdAt                                 DateTime         @default(now())
  updatedAt                                 DateTime         @updatedAt
  currentReleaseId                          String?          @unique
  approvalEnabled                           Boolean          @default(false)
  accessMode                                String           @default("PUBLIC")
  Namespace                                 Namespace[]
  Release_Project_currentReleaseIdToRelease Release?         @relation("Project_currentReleaseIdToRelease", fields: [currentReleaseId], references: [id])
  ProjectLocale                             ProjectLocale[]
  ProjectMember                             ProjectMember[]
  ProjectOwner                              ProjectOwner[]
  Release_Release_projectIdToProject        Release[]        @relation("Release_projectIdToProject")
  ReleaseSession                            ReleaseSession[]
  User                                      User[]           @relation("ProjectUsers")
}

model ProjectLocale {
  projectId  String
  localeId   String
  enabled    Boolean   @default(true)
  disabledAt DateTime? @db.Timestamptz
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
  Locale     Locale    @relation(fields: [localeId], references: [id])
  Project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, localeId])
  @@index([localeId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectOwner {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Release {
  id                                                        String            @id @default(cuid())
  projectId                                                 String
  basedOnReleaseId                                          String?
  version                                                   Int
  note                                                      String?
  scope                                                     Json
  createdAt                                                 DateTime          @default(now()) @db.Timestamptz
  Project_Project_currentReleaseIdToRelease                 Project?          @relation("Project_currentReleaseIdToRelease")
  Release                                                   Release?          @relation("ReleaseToRelease", fields: [basedOnReleaseId], references: [id])
  other_Release                                             Release[]         @relation("ReleaseToRelease")
  Project_Release_projectIdToProject                        Project           @relation("Release_projectIdToProject", fields: [projectId], references: [id], onDelete: Cascade)
  ReleaseArtifact                                           ReleaseArtifact[]
  ReleaseSession_ReleaseSession_baseReleaseIdToRelease      ReleaseSession[]  @relation("ReleaseSession_baseReleaseIdToRelease")
  ReleaseSession_ReleaseSession_publishedReleaseIdToRelease ReleaseSession[]  @relation("ReleaseSession_publishedReleaseIdToRelease")

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model ReleaseArtifact {
  id         String   @id @default(cuid())
  releaseId  String
  localeCode String
  data       Json
  createdAt  DateTime @default(now()) @db.Timestamptz
  Release    Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, localeCode])
  @@index([localeCode])
}

model ReleaseSession {
  id                                                 String               @id @default(cuid())
  projectId                                          String
  status                                             ReleaseSessionStatus @default(DRAFT)
  baseReleaseId                                      String?
  scope                                              Json
  localeCodes                                        String[]
  note                                               String?
  validationErrors                                   Json?
  nextArtifacts                                      Json
  baseJson                                           String?
  nextJson                                           String?
  submittedAt                                        DateTime?            @db.Timestamptz
  reviewedAt                                         DateTime?            @db.Timestamptz
  reviewNote                                         String?
  publishedAt                                        DateTime?            @db.Timestamptz
  publishedReleaseId                                 String?
  expiresAt                                          DateTime?            @db.Timestamptz
  createdAt                                          DateTime             @default(now()) @db.Timestamptz
  updatedAt                                          DateTime             @updatedAt @db.Timestamptz
  Release_ReleaseSession_baseReleaseIdToRelease      Release?             @relation("ReleaseSession_baseReleaseIdToRelease", fields: [baseReleaseId], references: [id])
  Project                                            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Release_ReleaseSession_publishedReleaseIdToRelease Release?             @relation("ReleaseSession_publishedReleaseIdToRelease", fields: [publishedReleaseId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, status])
}

model Translation {
  id                                 String              @id @default(cuid())
  content                            String
  status                             TranslationStatus   @default(PENDING)
  isLlmTranslated                    Boolean             @default(false)
  reviewComment                      String?
  keyId                              String
  localeId                           String
  reviewerId                         String?
  createdAt                          DateTime            @default(now()) @db.Timestamptz
  updatedAt                          DateTime            @updatedAt @db.Timestamptz
  approvedAt                         DateTime?           @db.Timestamptz
  dueDate                            DateTime?           @db.Timestamptz
  priority                           TranslationPriority @default(MEDIUM)
  submitterId                        String?
  Key                                Key                 @relation(fields: [keyId], references: [id])
  Locale                             Locale              @relation(fields: [localeId], references: [id])
  User_Translation_reviewerIdToUser  User?               @relation("Translation_reviewerIdToUser", fields: [reviewerId], references: [id])
  User_Translation_submitterIdToUser User?               @relation("Translation_submitterIdToUser", fields: [submitterId], references: [id])

  @@unique([keyId, localeId])
  @@index([priority, updatedAt])
  @@index([status, reviewerId])
  @@index([status, submitterId])
}

model User {
  id                                        String             @id @default(cuid())
  username                                  String             @unique
  email                                     String?            @unique
  role                                      UserRole           @default(EDITOR)
  externalId                                String?            @unique
  createdAt                                 DateTime           @default(now()) @db.Timestamptz
  updatedAt                                 DateTime           @updatedAt @db.Timestamptz
  avatar                                    String?
  mobile                                    String?
  name                                      String?
  provider                                  String?
  AuditLog                                  AuditLog[]
  EnterpriseMember                          EnterpriseMember[]
  ProjectMember                             ProjectMember[]
  ProjectOwner                              ProjectOwner[]
  Translation_Translation_reviewerIdToUser  Translation[]      @relation("Translation_reviewerIdToUser")
  Translation_Translation_submitterIdToUser Translation[]      @relation("Translation_submitterIdToUser")
  Project                                   Project[]          @relation("ProjectUsers")
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION
  LLM
}

enum AuditScopeType {
  GLOBAL
  PROJECT
}

enum KeyType {
  TEXT
  RICH_TEXT
  ASSET
}

enum ReleaseSessionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  EXPIRED
}

enum TranslationPriority {
  LOW
  MEDIUM
  HIGH
}

enum TranslationStatus {
  PENDING
  TRANSLATING
  REVIEWING
  APPROVED
  PUBLISHED
}

enum UserRole {
  ADMIN
  EDITOR
  REVIEWER
}

// 翻译供应商配置
model TranslationProvider {
  id                String   @id @default(cuid())
  name              String   // 显示名称
  type              TranslationProviderType
  baseUrl           String   // API基础地址
  apiKeyEncrypted   String   // 加密的API Key
  config            Json     // 额外配置参数
  isEnabled         Boolean  @default(true)
  isDefault         Boolean  @default(false)  // 默认供应商
  rateLimitPerMin   Int      @default(60)     // 每分钟请求限制
  maxCharsPerReq    Int      @default(5000)   // 单次最大字符数
  maxTextsPerReq    Int      @default(100)    // 单次最大文本数
  timeoutMs         Int      @default(30000)  // 请求超时
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  
  TranslationJob    TranslationJob[]
  TranslationCost   TranslationCost[]

  @@index([type, isEnabled])
}

// 翻译任务
model TranslationJob {
  id                String            @id @default(cuid())
  providerId        String
  projectId         String?
  status            TranslationJobStatus @default(PENDING)
  sourceLanguage    String
  targetLanguage    String
  texts             String[]          // 原文数组
  results           String[]          // 翻译结果
  error             String?           // 错误信息
  characterCount    Int               // 字符数统计
  tokenCount        Int?              // Token数（AI翻译）
  createdAt         DateTime          @default(now()) @db.Timestamptz
  completedAt       DateTime?         @db.Timestamptz
  
  Provider          TranslationProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, createdAt])
  @@index([projectId, status])
  @@index([createdAt])
}

// 翻译成本统计
model TranslationCost {
  id                String   @id @default(cuid())
  providerId        String
  projectId         String?
  characterCount    Int      // 字符数
  tokenCount        Int?     // Token数
  estimatedCost     Float    // 估算成本（USD）
  actualCost        Float?   // 实际成本（对账后）
  billingPeriod     String?  // 账单周期（如"2024-01"）
  createdAt         DateTime @default(now()) @db.Timestamptz
  
  Provider          TranslationProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, billingPeriod])
  @@index([projectId, createdAt])
}

enum TranslationProviderType {
  GOOGLE
  DEEPL
  AZURE
  OPENAI
  BAIDU
  CUSTOM
  MOCK
  TENCENT
}

enum TranslationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL  // 部分成功（批量翻译中部分失败）
}
