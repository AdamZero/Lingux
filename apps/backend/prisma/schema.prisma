// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  baseLocale  String   @default("zh-CN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  namespaces  Namespace[]
  projectLocales ProjectLocale[]
  users       User[]      @relation("ProjectUsers")
  currentReleaseId String?   @unique
  currentRelease   Release?   @relation("ProjectCurrentRelease", fields: [currentReleaseId], references: [id], onDelete: SetNull)
  releases          Release[]  @relation("ProjectReleases")
  releaseSessions   ReleaseSession[]
}

model Locale {
  id        String   @id @default(cuid())
  code      String   @unique // e.g., "en-US"
  name      String   // e.g., "English"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectLocales ProjectLocale[]
  translations Translation[]
}

model ProjectLocale {
  projectId  String
  localeId   String
  enabled    Boolean  @default(true)
  disabledAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locale  Locale  @relation(fields: [localeId], references: [id], onDelete: Restrict)

  @@id([projectId, localeId])
  @@index([localeId])
}

model Namespace {
  id          String   @id @default(cuid())
  name        String   // e.g., "common"
  description String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  keys Key[]

  @@unique([projectId, name])
}

enum KeyType {
  TEXT
  RICH_TEXT
  ASSET
}

model Key {
  id          String   @id @default(cuid())
  name        String   // e.g., "login.submit"
  description String?
  type        KeyType  @default(TEXT)
  namespaceId String
  namespace   Namespace @relation(fields: [namespaceId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations Translation[]

  @@unique([namespaceId, name])
}

enum TranslationStatus {
  PENDING      // 待翻译
  TRANSLATING  // 翻译中
  REVIEWING    // 审核中
  APPROVED     // 已审核
  PUBLISHED    // 已发布
}

model Translation {
  id             String            @id @default(cuid())
  content        String
  status         TranslationStatus @default(PENDING)
  isLlmTranslated Boolean           @default(false)
  reviewComment  String?
  
  keyId     String
  key       Key      @relation(fields: [keyId], references: [id])
  localeId  String
  locale    Locale   @relation(fields: [localeId], references: [id])
  
  reviewerId String?
  reviewer   User?    @relation("Reviewer", fields: [reviewerId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keyId, localeId])
}

enum UserRole {
  ADMIN
  EDITOR
  REVIEWER
}

enum AuditScopeType {
  GLOBAL
  PROJECT
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION
  LLM
}

model Enterprise {
  id         String   @id @default(cuid())
  name       String
  domain     String?  @unique
  externalId String?  @unique
  platform   String   // feishu, qixin, dingtalk
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    EnterpriseMember[]
}

model EnterpriseMember {
  id           String   @id @default(cuid())
  enterpriseId String
  userId       String
  role         String   @default("member") // admin, member
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, userId])
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  name       String?  // 真实姓名
  email      String?  @unique
  avatar     String?  // 头像 URL
  mobile     String?  // 手机号
  role       UserRole @default(EDITOR)
  externalId String?  @unique // For Feishu/DingTalk
  provider   String?  // 登录来源: feishu, dingtalk, qixin
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projects     Project[]          @relation("ProjectUsers")
  reviews      Translation[]      @relation("Reviewer")
  auditLogs    AuditLog[]
  enterprises  EnterpriseMember[]
}

model AuditLog {
  id            String         @id @default(cuid())
  action        String
  targetType    String
  targetId      String
  scopeType     AuditScopeType @default(GLOBAL)
  projectId     String?
  actorType     AuditActorType @default(SYSTEM)
  actorId       String?
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  correlationId String?
  version       Int            @default(1)
  payload       Json?
  createdAt     DateTime       @default(now())

  @@index([projectId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([userId, createdAt])
}

model Release {
  id              String   @id @default(cuid())
  projectId        String
  project          Project  @relation("ProjectReleases", fields: [projectId], references: [id], onDelete: Cascade)
  currentForProject Project? @relation("ProjectCurrentRelease")
  basedOnReleaseId String?
  basedOnRelease   Release? @relation("ReleaseBase", fields: [basedOnReleaseId], references: [id], onDelete: SetNull)
  derivedReleases  Release[] @relation("ReleaseBase")
  version          Int
  note             String?
  scope            Json
  createdAt        DateTime @default(now())

  artifacts ReleaseArtifact[]
  baseForReleaseSessions      ReleaseSession[] @relation("ReleaseSessionBase")
  publishedForReleaseSessions ReleaseSession[] @relation("ReleaseSessionPublished")

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model ReleaseArtifact {
  id        String   @id @default(cuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  localeCode String
  data      Json
  createdAt DateTime @default(now())

  @@unique([releaseId, localeCode])
  @@index([localeCode])
}

enum ReleaseSessionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  EXPIRED
}

model ReleaseSession {
  id            String              @id @default(cuid())
  projectId     String
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status        ReleaseSessionStatus @default(DRAFT)

  baseReleaseId String?
  baseRelease   Release?            @relation("ReleaseSessionBase", fields: [baseReleaseId], references: [id], onDelete: SetNull)

  scope         Json
  localeCodes   String[]
  note          String?

  validationErrors Json?
  nextArtifacts     Json
  baseJson          String?
  nextJson          String?

  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewNote    String?
  publishedAt   DateTime?
  publishedReleaseId String?
  publishedRelease   Release?       @relation("ReleaseSessionPublished", fields: [publishedReleaseId], references: [id], onDelete: SetNull)

  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([projectId, status])
  @@index([projectId, createdAt])
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   // e.g., "image", "video"
  description String?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
